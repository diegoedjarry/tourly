{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6788479223"
      },
      "android": {
        "serviceAccount": "@credentials.json",
        "track": "internal",
        "changesNotSentForReview": false
      }
    }
  }
}
