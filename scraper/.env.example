# Copy this file to .env and fill in your values
# NEVER commit .env to git — and never put a real key in this example file.

# Supabase — use the service-role key (bypasses RLS for backend writes).
# Find it in Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# Player full name — used to search ITF and pull their profile (optional)
PLAYER_NAME="Nicolas Jarry"
