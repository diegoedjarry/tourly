    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
